# ─────────────────────────────────────────────
# LoveQuest Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# NextAuth.js
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Neon PostgreSQL — https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Email — automatic via Google sign-in (enable once: npm run gmail:enable)
# Optional Gmail SMTP: npm run email:setup -- you@gmail.com app_password
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
MAIL_FROM=LoveQuest <you@gmail.com>

# Optional Resend fallback (test mode only emails your Resend account)
RESEND_API_KEY=
RESEND_FROM_EMAIL=LoveQuest <onboarding@resend.dev>
