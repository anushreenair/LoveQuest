# ─────────────────────────────────────────────
# LoveQuest Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

AUTH_SECRET=
AUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Partner email (required for beehoney413@gmail.com etc.)
# Run once: npm run email:setup -- you@gmail.com your-16-char-app-password
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
MAIL_FROM=LoveQuest <you@gmail.com>
GMAIL_SENDER=you@gmail.com

# Optional Brevo fallback (free at brevo.com — verify sender email once)
BREVO_API_KEY=

# Optional Resend (test mode only emails your Resend account)
RESEND_API_KEY=
RESEND_FROM_EMAIL=LoveQuest <onboarding@resend.dev>
